---
import DocLayout from '../layouts/DocLayout.astro';

const VERSION = '0.1.3';
const RELEASE_DATE = 'May 14, 2026';
const RELEASES_BASE = 'https://github.com/abhijathk/convertFlow/releases/latest/download';
---

<DocLayout
  title="Download convertFlow"
  description="Native installers for Windows, macOS, and Linux. Same app as the web version — no signup, no telemetry, your data stays on your machine."
  publishDate="2026-05-14"
  readMinutes={2}
  breadcrumb={[
    { label: 'convertFlow', href: '/' },
    { label: 'download' },
  ]}
  toc={[
    { id: 'download',       label: 'Download' },
    { id: 'whats-included', label: "What's included" },
    { id: 'requirements',   label: 'System requirements' },
    { id: 'install',        label: 'Install help', depth: 2 },
    { id: 'web-version',    label: 'Or use the web app' },
    { id: 'changelog',      label: "What's new" },
  ]}
>

<!-- ─────────────────────────────────────────────────────────────────────────
     HERO — auto-detected primary download
     ───────────────────────────────────────────────────────────────────── -->

<section class="hero" id="download">
  <div class="hero-row">
    <div class="hero-text">
      <p class="hero-eyebrow">free · open source · no signup</p>
      <h2 class="hero-title">Get convertFlow for your computer</h2>
      <p class="hero-sub">
        Same app as <a href="/">convertflow.live</a>, packaged as a native installer for Windows, macOS, and Linux.
        ~15 MB · works offline · your data never leaves your machine.
      </p>
    </div>
    <div class="hero-cta-wrap">
      <a class="hero-cta" id="auto-cta" href={`${RELEASES_BASE}/convertFlow_${VERSION}_x64-setup.exe`} data-platform="windows">
        <span class="hero-cta-icon" id="auto-cta-icon" aria-hidden="true">
          <!-- Windows icon as default; the inline script swaps this on load -->
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M2 5.5 9.4 4.5v7.4H2zM10.5 4.4 22 3v8.5h-11.5zM2 12.6h7.4V20L2 19zM10.5 12.6H22V21L10.5 19.6z"/></svg>
        </span>
        <span class="hero-cta-body">
          <span class="hero-cta-line" id="auto-cta-line">Download for Windows</span>
          <span class="hero-cta-sub" id="auto-cta-sub">v{VERSION} · .exe installer</span>
        </span>
      </a>
      <a class="hero-alt-link" href="#all-platforms">other platforms ↓</a>
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────────
     ALL PLATFORMS — explicit choices for users who know what they want
     ───────────────────────────────────────────────────────────────────── -->

<h2 id="all-platforms">All platforms</h2>

<div class="download-grid">

  <!-- WINDOWS -->
  <div class="download-card" id="windows">
    <div class="dl-icon win" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M2 5.5 9.4 4.5v7.4H2zM10.5 4.4 22 3v8.5h-11.5zM2 12.6h7.4V20L2 19zM10.5 12.6H22V21L10.5 19.6z"/></svg>
    </div>
    <div class="dl-body">
      <h3 class="dl-platform">Windows</h3>
      <p class="dl-meta">Windows 10+ · 64-bit</p>
    </div>
    <div class="dl-actions">
      <a class="dl-btn primary" href={`${RELEASES_BASE}/convertFlow_${VERSION}_x64-setup.exe`}>
        <span class="dl-btn-label">.exe</span>
        <span class="dl-btn-sub">setup</span>
      </a>
      <a class="dl-btn secondary" href={`${RELEASES_BASE}/convertFlow_${VERSION}_x64_en-US.msi`}>
        <span class="dl-btn-label">.msi</span>
        <span class="dl-btn-sub">enterprise</span>
      </a>
    </div>
  </div>

  <!-- macOS -->
  <div class="download-card" id="macos">
    <div class="dl-icon mac" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M18.7 17.9c-.4.8-.7 1.3-1.1 2-.7 1.1-1.6 2.4-2.7 2.4-1 0-1.3-.7-2.7-.7-1.4 0-1.7.7-2.7.7-1.1 0-1.9-1.2-2.6-2.3C5 17.6 4 14 5 11.5c.6-1.5 2-2.5 3.4-2.5 1.3 0 2.2.7 3.3.7 1 0 1.7-.7 3.2-.7 1.2 0 2.5.7 3.4 1.8-3 1.7-2.5 6 .4 7.1zM13.4 6c.6-.8 1.1-1.9.9-3.1-1.1.1-2.3.8-3 1.6-.6.8-1.2 1.9-1 3 1.2.1 2.4-.7 3.1-1.5z"/></svg>
    </div>
    <div class="dl-body">
      <h3 class="dl-platform">macOS</h3>
      <p class="dl-meta">macOS 11+ · universal binary (Apple Silicon + Intel)</p>
    </div>
    <div class="dl-actions">
      <a class="dl-btn primary" href={`${RELEASES_BASE}/convertFlow_${VERSION}_universal.dmg`}>
        <span class="dl-btn-label">.dmg</span>
        <span class="dl-btn-sub">universal</span>
      </a>
    </div>
  </div>

  <!-- LINUX -->
  <div class="download-card" id="linux">
    <div class="dl-icon ubuntu" aria-hidden="true">
      <svg viewBox="0 0 256 256" width="40" height="40" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Linux">
        <circle cx="128" cy="128" r="128" fill="#E95420"/>
        <g stroke="white" stroke-width="22" stroke-linecap="round" fill="none">
          <line x1="128" y1="128" x2="200" y2="88"/>
          <line x1="128" y1="128" x2="200" y2="168"/>
          <line x1="128" y1="128" x2="48"  y2="128"/>
        </g>
        <g fill="white">
          <circle cx="128" cy="128" r="28"/>
          <circle cx="200" cy="88"  r="22"/>
          <circle cx="200" cy="168" r="22"/>
          <circle cx="48"  cy="128" r="22"/>
        </g>
      </svg>
    </div>
    <div class="dl-body">
      <h3 class="dl-platform">Linux</h3>
      <p class="dl-meta">x86_64 · most distros</p>
    </div>
    <div class="dl-actions">
      <a class="dl-btn primary" href={`${RELEASES_BASE}/convertFlow_${VERSION}_amd64.AppImage`}>
        <span class="dl-btn-label">AppImage</span>
        <span class="dl-btn-sub">any distro</span>
      </a>
      <a class="dl-btn secondary" href={`${RELEASES_BASE}/convertFlow_${VERSION}_amd64.deb`}>
        <span class="dl-btn-label">.deb</span>
        <span class="dl-btn-sub">Debian/Ubuntu</span>
      </a>
      <a class="dl-btn secondary" href={`${RELEASES_BASE}/convertFlow-${VERSION}-1.x86_64.rpm`}>
        <span class="dl-btn-label">.rpm</span>
        <span class="dl-btn-sub">Fedora/RHEL</span>
      </a>
    </div>
  </div>

</div>

<p class="dl-foot">
  Latest version: <strong>v{VERSION}</strong> · released {RELEASE_DATE} ·
  <a href="https://github.com/abhijathk/convertFlow/releases" target="_blank" rel="noopener noreferrer">all releases</a> ·
  <a href="/latest.json" target="_blank" rel="noopener noreferrer">manifest</a>
</p>

<!-- ─────────────────────────────────────────────────────────────────────────
     INFO SECTIONS
     ───────────────────────────────────────────────────────────────────── -->

<h2 id="whats-included">What's included</h2>

<div class="feature-grid">
  <div class="feature">
    <span class="feature-icon" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 5l6-3 6 3v6l-6 3-6-3V5Z"/>
        <polyline points="2,5 8,8 14,5"/>
        <line x1="8" y1="8" x2="8" y2="14"/>
      </svg>
    </span>
    <div class="feature-text">
      <strong>Everything in the web app</strong>
      <span>Convert, Chunk, Editor, all 17 utilities — bit-for-bit identical to <a href="/">convertflow.live</a>.</span>
    </div>
  </div>
  <div class="feature">
    <span class="feature-icon" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 1v5M11 1v5"/>
        <rect x="3.5" y="6" width="9" height="3" rx="0.5"/>
        <path d="M8 9v3"/>
        <circle cx="8" cy="13.5" r="0.8" fill="currentColor" stroke="none"/>
      </svg>
    </span>
    <div class="feature-text">
      <strong>Works offline</strong>
      <span>No network required after install. HuggingFace pushes still need internet when you trigger them.</span>
    </div>
  </div>
  <div class="feature">
    <span class="feature-icon" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 4a1 1 0 0 1 1-1h3l2 2h5a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4Z"/>
      </svg>
    </span>
    <div class="feature-text">
      <strong>Native file system access</strong>
      <span>Drag large JSONLs straight from your file explorer — no browser upload limits.</span>
    </div>
  </div>
  <div class="feature">
    <span class="feature-icon" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="7" width="10" height="7" rx="1"/>
        <path d="M5 7V5a3 3 0 0 1 6 0v2"/>
      </svg>
    </span>
    <div class="feature-text">
      <strong>100% local</strong>
      <span>Your data stays on your machine. No telemetry, no accounts, no cloud sync.</span>
    </div>
  </div>
</div>

<h2 id="requirements">System requirements</h2>

<table class="req-table">
  <thead><tr><th>OS</th><th>Minimum</th><th>Recommended</th><th>Architecture</th></tr></thead>
  <tbody>
    <tr><td>Windows</td><td>Windows 10</td><td>Windows 11</td><td>x86_64 (Intel / AMD)</td></tr>
    <tr><td>macOS</td><td>11 (Big Sur)</td><td>14 (Sonoma)+</td><td>Apple Silicon (preferred) or Intel</td></tr>
    <tr><td>Linux</td><td>Ubuntu 20.04 / Debian 11 equivalent</td><td>Ubuntu 22.04+</td><td>x86_64</td></tr>
  </tbody>
</table>

<p>~250 MB free disk space. WebView2 / WebKitGTK is provided by the OS (Tauri uses the system browser engine, no Chromium bundled).</p>

<h3 id="install">Install help</h3>

<details class="install-details">
  <summary>Windows: "Windows protected your PC"</summary>
  <p>
    Until the Windows installer is code-signed (~ $300/year EV cert), SmartScreen flags new binaries.
    Click <strong>More info</strong> → <strong>Run anyway</strong>. This is a one-time confirmation; subsequent launches won't prompt.
  </p>
</details>

<details class="install-details">
  <summary>macOS: "Apple cannot check it for malicious software"</summary>
  <p>
    Until macOS notarization is set up, Gatekeeper blocks new apps.
    Right-click the app → <strong>Open</strong> → click <strong>Open</strong> in the dialog.
    Alternatively: <code>System Settings → Privacy &amp; Security → Open Anyway</code>.
    The .dmg is unsigned but the binary inside is identical to what GitHub Actions built — verify with the SHA-256 on the release page.
  </p>
</details>

<details class="install-details">
  <summary>Linux: AppImage won't run</summary>
  <p>
    Make it executable first:
    <code style="display:block;margin-top:6px;padding:6px 10px;background:var(--bg);border-radius:3px">chmod +x convertFlow_{VERSION}_amd64.AppImage</code>
    Then double-click or run <code>./convertFlow_{VERSION}_amd64.AppImage</code>. On some distros you may need <code>libfuse2</code>: <code>sudo apt install libfuse2</code>.
  </p>
</details>

<details class="install-details">
  <summary>How do I uninstall?</summary>
  <p>
    <strong>Windows:</strong> Settings → Apps → convertFlow → Uninstall, or run the installer again and choose "Remove".<br>
    <strong>macOS:</strong> Drag <code>convertFlow.app</code> from Applications to the Trash.<br>
    <strong>Linux:</strong> Delete the <code>.AppImage</code> file, or <code>sudo apt remove convertflow</code> if you installed the .deb.
  </p>
</details>

<h2 id="web-version">Or use the web app</h2>

<p>
  No download needed. <a href="/">convertflow.live</a> works in any modern browser — same UI, same features, same 100%-local processing.
  Want it pinned to your dock or taskbar? Click the install icon in Chrome / Edge's URL bar to "install" the PWA.
</p>

<h2 id="changelog">What's new</h2>

<h3>v{VERSION} — {RELEASE_DATE}</h3>
<p>Initial public desktop release. Same feature set as <a href="/help">the web app</a>, packaged as a native installer.</p>

</DocLayout>

<!-- Platform-detection script: re-targets the big hero button based on
     the user's OS. Falls back to the Windows default if detection fails. -->
<script is:inline define:vars={{ RELEASES_BASE, VERSION }}>
  (function () {
    try {
      var ua = navigator.userAgent || '';
      var platform = '';
      var detected = null;

      if (/Win(dows)?/i.test(ua)) {
        detected = {
          platform: 'windows',
          line: 'Download for Windows',
          sub: 'v' + VERSION + ' · .exe installer',
          href: RELEASES_BASE + '/convertFlow_' + VERSION + '_x64-setup.exe',
          icon: '<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M2 5.5 9.4 4.5v7.4H2zM10.5 4.4 22 3v8.5h-11.5zM2 12.6h7.4V20L2 19zM10.5 12.6H22V21L10.5 19.6z"/></svg>',
        };
      } else if (/Mac|iPhone|iPad/i.test(ua)) {
        // Universal binary — runs on Apple Silicon and Intel.
        detected = {
          platform: 'macos',
          line: 'Download for macOS',
          sub: 'v' + VERSION + ' · universal .dmg',
          href: RELEASES_BASE + '/convertFlow_' + VERSION + '_universal.dmg',
          icon: '<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M18.7 17.9c-.4.8-.7 1.3-1.1 2-.7 1.1-1.6 2.4-2.7 2.4-1 0-1.3-.7-2.7-.7-1.4 0-1.7.7-2.7.7-1.1 0-1.9-1.2-2.6-2.3C5 17.6 4 14 5 11.5c.6-1.5 2-2.5 3.4-2.5 1.3 0 2.2.7 3.3.7 1 0 1.7-.7 3.2-.7 1.2 0 2.5.7 3.4 1.8-3 1.7-2.5 6 .4 7.1zM13.4 6c.6-.8 1.1-1.9.9-3.1-1.1.1-2.3.8-3 1.6-.6.8-1.2 1.9-1 3 1.2.1 2.4-.7 3.1-1.5z"/></svg>',
        };
      } else if (/Linux/i.test(ua)) {
        detected = {
          platform: 'linux',
          line: 'Download for Linux',
          sub: 'v' + VERSION + ' · AppImage',
          href: RELEASES_BASE + '/convertFlow_' + VERSION + '_amd64.AppImage',
          icon: '<svg viewBox="0 0 256 256" width="22" height="22"><circle cx="128" cy="128" r="128" fill="#E95420"/><g stroke="white" stroke-width="22" stroke-linecap="round" fill="none"><line x1="128" y1="128" x2="200" y2="88"/><line x1="128" y1="128" x2="200" y2="168"/><line x1="128" y1="128" x2="48" y2="128"/></g><g fill="white"><circle cx="128" cy="128" r="28"/><circle cx="200" cy="88" r="22"/><circle cx="200" cy="168" r="22"/><circle cx="48" cy="128" r="22"/></g></svg>',
        };
      }

      if (!detected) return;

      var cta = document.getElementById('auto-cta');
      var line = document.getElementById('auto-cta-line');
      var sub = document.getElementById('auto-cta-sub');
      var icon = document.getElementById('auto-cta-icon');
      if (cta) cta.setAttribute('href', detected.href);
      if (cta) cta.setAttribute('data-platform', detected.platform);
      if (line) line.textContent = detected.line;
      if (sub) sub.textContent = detected.sub;
      if (icon) icon.innerHTML = detected.icon;
    } catch (_) {
      /* swallow — Windows default is fine */
    }
  })();
</script>

<style>
  /* ── HERO ─────────────────────────────────────────────────────────────── */
  .hero {
    margin: 20px 0 32px;
    padding: 24px 26px;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent) 10%, var(--surface)) 0%,
      var(--surface) 60%
    );
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--border));
    border-radius: 12px;
  }
  .hero-row {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }
  .hero-text {
    flex: 1 1 280px;
    min-width: 0;
  }
  .hero-eyebrow {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin: 0 0 8px;
    font-weight: 600;
  }
  .hero-title {
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 8px;
    line-height: 1.25;
    border-top: none !important;
    padding-top: 0 !important;
  }
  .hero-sub {
    font-size: 13px;
    color: var(--ink-dim);
    margin: 0;
    line-height: 1.6;
  }
  .hero-cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
    flex-shrink: 0;
  }
  /* DocLayout sets .doc-main :global(a) { color: var(--accent) } which
     beats .hero-cta on specificity. Using a.hero-cta to win the cascade
     so the button text is readable on the accent fill. */
  a.hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 12px 22px;
    background: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
    border-radius: 7px;
    text-decoration: none;
    transition: transform 0.08s, box-shadow 0.12s;
    min-width: 240px;
  }
  a.hero-cta:hover {
    text-decoration: none;
    color: var(--bg);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -6px color-mix(in srgb, var(--accent) 60%, transparent);
  }
  a.hero-cta .hero-cta-line,
  a.hero-cta .hero-cta-sub {
    color: var(--bg);
  }
  .hero-cta-icon {
    line-height: 0;
    flex-shrink: 0;
  }
  .hero-cta-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .hero-cta-line {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
  }
  .hero-cta-sub {
    font-size: 11px;
    opacity: 0.85;
    line-height: 1.2;
  }
  .hero-alt-link {
    font-size: 11px;
    color: var(--ink-dim);
    text-align: center;
    text-decoration: none;
  }
  .hero-alt-link:hover { color: var(--accent); }

  /* ── ALL PLATFORMS GRID ──────────────────────────────────────────────── */
  .download-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 12px 0 16px;
  }
  .download-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.12s;
  }
  .download-card:hover {
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
  }
  .dl-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 8px;
    flex-shrink: 0;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .dl-icon.ubuntu {
    color: inherit;
    background: transparent;
    padding: 2px;
  }
  .dl-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1 1 0;
    min-width: 0;
  }
  .dl-platform {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    line-height: 1.25;
    border: none !important;
    padding: 0 !important;
  }
  .dl-meta {
    font-size: 11px;
    color: var(--ink-dim);
    margin: 0;
    line-height: 1.4;
  }
  .dl-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }
  .dl-btn {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 78px;
    padding: 6px 10px;
    border-radius: 5px;
    text-decoration: none;
    line-height: 1.15;
    white-space: nowrap;
    border: 1px solid transparent;
    transition: background 0.1s, border-color 0.1s, color 0.1s;
  }
  .dl-btn-label { font-size: 12px; font-weight: 600; }
  .dl-btn-sub { font-size: 10px; opacity: 0.7; font-weight: 400; margin-top: 1px; }
  a.dl-btn.primary {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  a.dl-btn.primary:hover {
    background: color-mix(in srgb, var(--accent) 88%, white);
    color: var(--bg);
    text-decoration: none;
  }
  a.dl-btn.primary .dl-btn-label,
  a.dl-btn.primary .dl-btn-sub {
    color: var(--bg);
  }
  .dl-btn.secondary {
    background: transparent;
    border-color: var(--border);
    color: var(--ink-dim);
  }
  .dl-btn.secondary:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    color: var(--accent);
    text-decoration: none;
  }

  /* ── Mobile fallback for cards ──────────────────────────────────────── */
  @media (max-width: 560px) {
    .download-card {
      flex-wrap: wrap;
      row-gap: 10px;
    }
    .dl-body { flex-basis: calc(100% - 64px); }
    .dl-actions { flex-basis: 100%; }
    .dl-btn { flex: 1 1 0; }
  }

  /* ── Footer ─────────────────────────────────────────────────────────── */
  .dl-foot {
    font-size: 12px;
    color: var(--ink-dim);
    margin-top: 4px;
  }
  .dl-foot a { color: var(--accent); text-decoration: none; }
  .dl-foot a:hover { text-decoration: underline; }

  /* ── Feature grid ───────────────────────────────────────────────────── */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
