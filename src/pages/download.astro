<style>
  .download-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin: 20px 0 12px;
  }
  .download-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.1s, background 0.1s;
  }
  .download-card:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, var(--surface));
    text-decoration: none;
  }
  .dl-icon {
    color: var(--accent);
    flex-shrink: 0;
    line-height: 0;
  }
  /* Ubuntu icon ships its own colours — keep them intact regardless of theme. */
  .dl-icon.ubuntu { color: inherit; }
  .dl-icon.ubuntu svg { border-radius: 50%; }
  .dl-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }
  .dl-platform {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
  }
  .dl-meta {
    font-size: 11px;
    color: var(--ink-dim);
  }
  .dl-meta-sub {
    font-size: 11px;
    color: var(--muted);
    margin-top: 2px;
  }
  .dl-meta-sub a {
    color: var(--accent);
    text-decoration: none;
  }
  .dl-meta-sub a:hover { text-decoration: underline; }
  .dl-cta {
    font-size: 12px;
    color: var(--accent);
    font-weight: 500;
    flex-shrink: 0;
  }
  .dl-foot {
    font-size: 12px;
    color: var(--ink-dim);
    margin-top: 0;
  }
</style>
