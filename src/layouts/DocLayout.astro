---
import '../styles/globals.css';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  readMinutes: number;
  breadcrumb: { label: string; href?: string }[];
  toc: { id: string; label: string; depth?: number }[];
}

const { title, description, publishDate, readMinutes, breadcrumb, toc } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0e1116" />
  <meta name="robots" content="index, follow, max-image-preview:large" />

  <title>{title} — convertFlow</title>
  <meta name="description" content={description} />
  <meta name="author" content="convertFlow" />

  <link rel="canonical" href={`https://convertflow.live${Astro.url.pathname.replace(/\/$/, '')}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="convertFlow" />
  <meta property="og:title" content={`${title} — convertFlow`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://convertflow.live${Astro.url.pathname}`} />
  <meta property="og:image" content="https://convertflow.live/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="article:published_time" content={publishDate} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — convertFlow`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://convertflow.live/og-image.png" />

  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="256x256" href="/favicon-256.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="icon" href="/favicon.ico" />

  <!-- JSON-LD: Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": publishDate,
    "dateModified": publishDate,
    "author": {
      "@type": "Organization",
      "name": "convertFlow",
      "url": "https://convertflow.live"
    },
    "publisher": {
      "@type": "Organization",
      "name": "convertFlow",
      "url": "https://convertflow.live"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://convertflow.live${Astro.url.pathname}`
    }
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumb.map((crumb, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": crumb.label,
      ...(crumb.href ? { "item": `https://convertflow.live${crumb.href}` } : {})
    }))
  })} />

  <script is:inline>
    (function() {
      const t = localStorage.getItem('dataprep-theme');
      document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark');
    })();
  </script>
</head>
<body class="doc-body">

  <header class="doc-topbar">
    <a href="/" class="brand">convertFlow</a>
    <nav class="doc-breadcrumb" aria-label="Breadcrumb">
      {breadcrumb.map((crumb, i) => (
        <>
          {i > 0 && <span aria-hidden="true" class="bc-sep">›</span>}
          {crumb.href
            ? <a href={crumb.href}>{crumb.label}</a>
            : <span aria-current="page">{crumb.label}</span>
          }
        </>
      ))}
    </nav>
    <a href="/" class="launch-cta">open tool →</a>
  </header>

  <div class="doc-layout">
    <aside class="sidebar" aria-label="Table of contents">
      <nav>
        <p class="toc-heading">contents</p>
        <ul class="toc-tree">
          {(() => {
            const groups: { top: typeof toc[number]; subs: typeof toc[number][] }[] = [];
            for (const item of toc) {
              if (!item.depth || item.depth < 2) groups.push({ top: item, subs: [] });
              else if (groups.length > 0) groups[groups.length - 1].subs.push(item);
              else groups.push({ top: item, subs: [] });
            }
            return groups.map(g => (
              g.subs.length === 0 ? (
                <li class="toc-leaf"><a href={`#${g.top.id}`}>{g.top.label}</a></li>
              ) : (
                <li class="toc-branch">
                  <details open>
                    <summary>
                      <span class="toc-toggle" aria-hidden="true">▸</span>
                      <a href={`#${g.top.id}`}>{g.top.label}</a>
                    </summary>
                    <ul class="toc-subs">
                      {g.subs.map(s => (
                        <li><a href={`#${s.id}`}>{s.label}</a></li>
                      ))}
                    </ul>
                  </details>
                </li>
              )
            ));
          })()}
        </ul>
      </nav>
    </aside>

    <main class="doc-main" id="main-content">
      <h1>{title}</h1>
      <p class="doc-meta">Published {publishDate} · {readMinutes} min read</p>

      <slot />
    </main>
  </div>

</body>
</html>

<style>
  .doc-body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'IBM Plex Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
  }

  .doc-topbar {
    display: flex;
    align-items: center;
    gap: 16px;
    height: 44px;
    padding: 0 24px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .brand {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    flex-shrink: 0;
  }
  .brand:hover { color: var(--accent); }

  .doc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--ink-dim);
    flex: 1;
  }

  .doc-breadcrumb a { color: var(--ink-dim); text-decoration: none; }
  .doc-breadcrumb a:hover { color: var(--ink); }
  .doc-breadcrumb span[aria-current] { color: var(--ink); }
  .bc-sep { color: var(--muted); }

  .launch-cta {
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    flex-shrink: 0;
  }
  .launch-cta:hover { text-decoration: underline; }

  .doc-layout {
    display: flex;
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 24px;
    gap: 48px;
  }

  .sidebar {
    width: 200px;
    flex-shrink: 0;
    padding-top: 32px;
  }

  .sidebar nav {
    position: sticky;
    top: 68px;
    max-height: calc(100vh - 88px);
    overflow-y: auto;
    padding-right: 8px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .sidebar nav::-webkit-scrollbar { width: 6px; }
  .sidebar nav::-webkit-scrollbar-track { background: transparent; }
  .sidebar nav::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  .sidebar nav::-webkit-scrollbar-thumb:hover { background: var(--ink-dim); }

  .toc-heading {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 10px;
  }

  .sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sidebar a {
    font-size: 12px;
    color: var(--ink-dim);
    text-decoration: none;
    display: block;
  }
  .sidebar a:hover { color: var(--accent); }

  .toc-sub a { padding-left: 10px; font-size: 11px; }

  .toc-tree summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    user-select: none;
  }
  .toc-tree summary::-webkit-details-marker { display: none; }
  .toc-toggle {
    display: inline-block;
    font-size: 9px;
    color: var(--muted);
    transition: transform 0.12s;
    flex-shrink: 0;
    width: 10px;
  }
  details[open] > summary .toc-toggle { transform: rotate(90deg); }
  .toc-leaf { padding-left: 14px; }
  .toc-branch > details > summary > a { flex: 1; }
  .toc-subs {
    list-style: none;
    padding: 4px 0 0 14px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .toc-subs a { font-size: 11px; color: var(--ink-dim); }
  .toc-subs a:hover { color: var(--accent); }

  .doc-main {
    flex: 1;
    min-width: 0;
    padding: 32px 0 80px;
    max-width: 68ch;
  }

  .doc-main :global(h1) {
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .doc-meta {
    font-size: 12px;
    color: var(--ink-dim);
    margin: 0 0 32px;
  }

  .doc-main :global(h2) {
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    margin: 40px 0 14px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .doc-main :global(h3) {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    margin: 24px 0 10px;
  }

  .doc-main :global(p) {
    margin: 0 0 16px;
    color: var(--ink);
  }

  .doc-main :global(code) {
    font-family: inherit;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 1px 5px;
    font-size: 13px;
    color: var(--syntax-str);
  }

  .doc-main :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 16px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    margin: 0 0 20px;
  }

  .doc-main :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--ink);
  }

  .doc-main :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin: 0 0 24px;
  }

  .doc-main :global(th) {
    text-align: left;
    font-weight: 500;
    padding: 7px 12px;
    border-bottom: 2px solid var(--border);
    color: var(--ink-dim);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .doc-main :global(td) {
    padding: 7px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .doc-main :global(tr:last-child td) { border-bottom: none; }

  .doc-main :global(ul), .doc-main :global(ol) {
    margin: 0 0 16px;
    padding-left: 20px;
  }

  .doc-main :global(li) { margin-bottom: 6px; }

  .doc-main :global(a) { color: var(--accent); text-decoration: none; }
  .doc-main :global(a:hover) { text-decoration: underline; }

  .doc-main :global(.callout) {
    border-left: 3px solid var(--accent);
    padding: 12px 16px;
    background: var(--surface);
    margin: 0 0 20px;
    border-radius: 0 3px 3px 0;
  }

  @media (max-width: 700px) {
    .sidebar { display: none; }
    .doc-layout { padding: 0 16px; }
    .doc-topbar { padding: 0 16px; }
  }
</style>
