---
import '../styles/globals.css';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  readMinutes: number;
  breadcrumb: { label: string; href?: string }[];
  toc: { id: string; label: string; depth?: number }[];
}

const { title, description, publishDate, readMinutes, breadcrumb, toc } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — DataPrep</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    (function() {
      const t = localStorage.getItem('dataprep-theme');
      document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark');
    })();
  </script>
  <!-- Plausible analytics (replace data-domain when live) -->
  <!-- <script defer data-domain="dataprep.tool" src="https://plausible.io/js/script.js"></script> -->
</head>
<body class="doc-body">

  <header class="doc-topbar">
    <a href="/" class="brand">dataprep</a>
    <nav class="doc-breadcrumb" aria-label="Breadcrumb">
      {breadcrumb.map((crumb, i) => (
        <>
          {i > 0 && <span aria-hidden="true" class="bc-sep">›</span>}
          {crumb.href
            ? <a href={crumb.href}>{crumb.label}</a>
            : <span aria-current="page">{crumb.label}</span>
          }
        </>
      ))}
    </nav>
    <a href="/" class="launch-cta">open tool →</a>
  </header>

  <div class="doc-layout">
    <aside class="sidebar" aria-label="Table of contents">
      <nav>
        <p class="toc-heading">contents</p>
        <ul>
          {toc.map(item => (
            <li class={item.depth === 2 ? 'toc-sub' : ''}>
              <a href={`#${item.id}`}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <main class="doc-main" id="main-content">
      <h1>{title}</h1>
      <p class="doc-meta">Published {publishDate} · {readMinutes} min read</p>

      <slot />
    </main>
  </div>

</body>
</html>

<style>
  .doc-body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'IBM Plex Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
  }

  .doc-topbar {
    display: flex;
    align-items: center;
    gap: 16px;
    height: 44px;
    padding: 0 24px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .brand {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    flex-shrink: 0;
  }
  .brand:hover { color: var(--accent); }

  .doc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--ink-dim);
    flex: 1;
  }

  .doc-breadcrumb a { color: var(--ink-dim); text-decoration: none; }
  .doc-breadcrumb a:hover { color: var(--ink); }
  .doc-breadcrumb span[aria-current] { color: var(--ink); }
  .bc-sep { color: var(--muted); }

  .launch-cta {
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    flex-shrink: 0;
  }
  .launch-cta:hover { text-decoration: underline; }

  .doc-layout {
    display: flex;
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 24px;
    gap: 48px;
  }

  .sidebar {
    width: 200px;
    flex-shrink: 0;
    padding-top: 32px;
  }

  .sidebar nav {
    position: sticky;
    top: 68px;
  }

  .toc-heading {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 10px;
  }

  .sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sidebar a {
    font-size: 12px;
    color: var(--ink-dim);
    text-decoration: none;
    display: block;
  }
  .sidebar a:hover { color: var(--accent); }

  .toc-sub a { padding-left: 10px; font-size: 11px; }

  .doc-main {
    flex: 1;
    min-width: 0;
    padding: 32px 0 80px;
    max-width: 68ch;
  }

  .doc-main :global(h1) {
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .doc-meta {
    font-size: 12px;
    color: var(--ink-dim);
    margin: 0 0 32px;
  }

  .doc-main :global(h2) {
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    margin: 40px 0 14px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .doc-main :global(h3) {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    margin: 24px 0 10px;
  }

  .doc-main :global(p) {
    margin: 0 0 16px;
    color: var(--ink);
  }

  .doc-main :global(code) {
    font-family: inherit;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 1px 5px;
    font-size: 13px;
    color: var(--syntax-str);
  }

  .doc-main :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 16px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    margin: 0 0 20px;
  }

  .doc-main :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--ink);
  }

  .doc-main :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin: 0 0 24px;
  }

  .doc-main :global(th) {
    text-align: left;
    font-weight: 500;
    padding: 7px 12px;
    border-bottom: 2px solid var(--border);
    color: var(--ink-dim);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .doc-main :global(td) {
    padding: 7px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .doc-main :global(tr:last-child td) { border-bottom: none; }

  .doc-main :global(ul), .doc-main :global(ol) {
    margin: 0 0 16px;
    padding-left: 20px;
  }

  .doc-main :global(li) { margin-bottom: 6px; }

  .doc-main :global(a) { color: var(--accent); text-decoration: none; }
  .doc-main :global(a:hover) { text-decoration: underline; }

  .doc-main :global(.callout) {
    border-left: 3px solid var(--accent);
    padding: 12px 16px;
    background: var(--surface);
    margin: 0 0 20px;
    border-radius: 0 3px 3px 0;
  }

  @media (max-width: 700px) {
    .sidebar { display: none; }
    .doc-layout { padding: 0 16px; }
    .doc-topbar { padding: 0 16px; }
  }
</style>
